# Copy to .env and fill in — used by deploy.mjs (npm run deploy / npm run bump).
# Never commit .env (it contains your HA token; .env is in .gitignore).

# Base URL of your Home Assistant instance, no trailing slash
HA_URL=http://homeassistant.local:8123

# Long-Lived Access Token: HA → Profile → Security → Long-lived access tokens
HA_TOKEN=
