{
  "name": "electricity-panel-card",
  "version": "5.1.0",
  "description": "Home Assistant custom Lovelace card for electricity panel management",
  "keywords": ["home-assistant", "lovelace", "custom-card", "electricity", "hdo"],
  "license": "MIT",
  "type": "module",
  "main": "dist/electricity-panel-card.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "watch": "vite build --watch",
    "dev": "vite",
    "deploy": "node deploy.mjs",
    "bump": "node deploy.mjs --bump"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
